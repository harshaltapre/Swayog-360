generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
  PARTNER
  CUSTOMER
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PENDING
  PAID
  OVERDUE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StockStatus {
  ADEQUATE
  LOW
  CRITICAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  CANCELLED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentMethodProvider {
  STRIPE
}

enum PaymentTransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  name      String
  phone     String?
  avatarUrl String?
  language  String   @default("English (India)")
  notificationSystemAlerts     Boolean @default(true)
  notificationFinancialReports Boolean @default(true)
  notificationMarketingUpdates Boolean @default(false)
  notificationMaintenanceAlerts Boolean @default(true)
  notificationProjectUpdates   Boolean @default(true)
  twoFactorEnabled             Boolean @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdCustomers Customer[] @relation("CustomerCreatedBy")
  customerProfile  Customer?   @relation("CustomerUser")
  notifications    Notification[]
}

model Customer {
  id                          String                 @id @default(cuid())
  customerCode                String                 @unique
  userId                      String?                @unique
  name                        String
  email                       String?                @unique
  phone                       String?
  zone                        String?
  avatarUrl                   String?
  language                    String                 @default("English (India)")
  billingAddressLine1         String?
  billingAddressLine2         String?
  billingCity                 String?
  billingState                String?
  billingPostalCode           String?
  billingCountry              String?                @default("India")
  notificationSystemAlerts    Boolean                @default(true)
  notificationFinancialReports Boolean               @default(true)
  notificationMarketingUpdates Boolean               @default(false)
  notificationMaintenanceAlerts Boolean              @default(true)
  notificationProjectUpdates  Boolean                @default(true)
  twoFactorEnabled            Boolean                @default(false)
  stripeCustomerId            String?                @unique
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt

  createdById         String?
  createdBy           User?                  @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  user                User?                  @relation("CustomerUser", fields: [userId], references: [id])
  installation        Installation?
  devices             Device[]
  serviceRequests     ServiceRequest[]
  serviceAppointments ServiceAppointment[]
  invoices            Invoice[]
  paymentMethods      PaymentMethod[]
  paymentTransactions PaymentTransaction[]
  feedbackEntries     CustomerFeedback[]
  notifications       Notification[]
  activityEvents      ActivityEvent[]
}

model Employee {
  id           String   @id @default(cuid())
  employeeCode String   @unique
  name         String
  email        String?  @unique
  phone        String?
  zone         String?
  title        String?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Partner {
  id            String   @id @default(cuid())
  partnerCode   String   @unique
  name          String
  company       String?
  email         String?  @unique
  phone         String?
  zone          String?
  commissionPct Int      @default(0)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Project {
  id           String   @id @default(cuid())
  projectCode  String   @unique
  title        String
  customerName String
  partnerName  String?
  status       String   @default("PLANNED")
  value        Decimal  @default(0) @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Complaint {
  id           String          @id @default(cuid())
  complaintCode String         @unique
  title        String
  customerName String
  priority     Priority        @default(MEDIUM)
  status       ComplaintStatus @default(OPEN)
  assignedTo   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Task {
  id           String      @id @default(cuid())
  taskCode     String      @unique
  title        String
  description  String?
  priority     Priority    @default(MEDIUM)
  status       TaskStatus  @default(PENDING)
  dueDate      DateTime?
  assignedTo   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Invoice {
  id                      String               @id @default(cuid())
  invoiceCode             String               @unique
  customerId              String
  customerName            String
  amount                  Decimal              @default(0) @db.Decimal(12, 2)
  status                  InvoiceStatus        @default(DRAFT)
  dueDate                 DateTime?
  description             String?
  paidAt                  DateTime?
  stripeCheckoutSessionId String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  customer            Customer             @relation(fields: [customerId], references: [id])
  lineItems           InvoiceLineItem[]
  paymentTransactions PaymentTransaction[]
}

model InventoryItem {
  id           String      @id @default(cuid())
  itemCode     String      @unique
  name         String
  category     String
  quantity     Int         @default(0)
  minThreshold Int         @default(0)
  status       StockStatus @default(ADEQUATE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model AttendanceLog {
  id           String           @id @default(cuid())
  employeeName String
  logDate      DateTime
  status       AttendanceStatus @default(PRESENT)
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model ServiceRequest {
  id              String               @id @default(cuid())
  requestCode     String               @unique
  customerId      String
  customerName    String
  title           String
  description     String?
  issueType       String
  priority        Priority             @default(MEDIUM)
  status          ServiceRequestStatus @default(OPEN)
  attachmentName  String?
  attachmentUrl   String?
  resolvedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  customer     Customer             @relation(fields: [customerId], references: [id])
  appointments ServiceAppointment[]
}

model Notification {
  id         String   @id @default(cuid())
  userId     String?
  customerId String?
  type       String
  category   String?
  title      String?
  message    String
  link       String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  entityType String
  entityId   String?
  changes    Json?
  createdAt  DateTime @default(now())
}

model Installation {
  id                    String                 @id @default(cuid())
  customerId            String                 @unique
  systemName            String
  systemSizeKw          Decimal                @default(0) @db.Decimal(12, 2)
  location              String
  status                String                 @default("ACTIVE")
  installedAt           DateTime?
  avgDailyGenerationKwh Decimal                @default(0) @db.Decimal(12, 2)
  monthlyProductionKwh  Decimal                @default(0) @db.Decimal(12, 2)
  totalSavingsAmount    Decimal                @default(0) @db.Decimal(12, 2)
  totalEnergySavedMwh   Decimal                @default(0) @db.Decimal(12, 2)
  warrantyYears         Int                    @default(25)
  panelCount            Int                    @default(0)
  panelModel            String?
  inverterModel         String?
  batteryModel          String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  customer   Customer                @relation(fields: [customerId], references: [id])
  devices    Device[]
  milestones InstallationMilestone[]
  metrics    InstallationMetric[]
}

model InstallationMilestone {
  id             String       @id @default(cuid())
  installationId String
  title          String
  description    String?
  milestoneType  String
  status         String       @default("COMPLETED")
  occurredAt     DateTime
  createdAt      DateTime     @default(now())

  installation Installation @relation(fields: [installationId], references: [id])
}

model InstallationMetric {
  id             String       @id @default(cuid())
  installationId String
  metricDate     DateTime
  generationKwh  Decimal      @default(0) @db.Decimal(12, 2)
  savingsAmount  Decimal      @default(0) @db.Decimal(12, 2)
  heatmapScore   Int          @default(0)
  createdAt      DateTime     @default(now())

  installation Installation @relation(fields: [installationId], references: [id])

  @@unique([installationId, metricDate])
}

model Device {
  id              String        @id @default(cuid())
  deviceCode      String        @unique
  customerId      String
  installationId  String?
  name            String
  type            String
  status          String        @default("ACTIVE")
  model           String?
  capacity        String?
  installDate     DateTime?
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  performance     Decimal?      @db.Decimal(5, 2)
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer     Customer      @relation(fields: [customerId], references: [id])
  installation Installation? @relation(fields: [installationId], references: [id])
}

model ServiceAppointment {
  id               String            @id @default(cuid())
  appointmentCode  String            @unique
  customerId       String
  serviceRequestId String?
  title            String
  description      String?
  scheduledFor     DateTime
  status           AppointmentStatus @default(SCHEDULED)
  location         String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  customer       Customer        @relation(fields: [customerId], references: [id])
  serviceRequest ServiceRequest? @relation(fields: [serviceRequestId], references: [id])
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  label       String
  description String?
  amount      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model PaymentMethod {
  id                    String                @id @default(cuid())
  customerId            String
  provider              PaymentMethodProvider @default(STRIPE)
  stripePaymentMethodId String                @unique
  brand                 String?
  last4                 String?
  expMonth              Int?
  expYear               Int?
  isDefault             Boolean               @default(false)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  customer            Customer             @relation(fields: [customerId], references: [id])
  paymentTransactions PaymentTransaction[]
}

model PaymentTransaction {
  id                      String                   @id @default(cuid())
  customerId              String
  invoiceId               String
  paymentMethodId         String?
  provider                PaymentMethodProvider   @default(STRIPE)
  status                  PaymentTransactionStatus @default(PENDING)
  amount                  Decimal                  @default(0) @db.Decimal(12, 2)
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?
  paidAt                  DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  customer      Customer       @relation(fields: [customerId], references: [id])
  invoice       Invoice        @relation(fields: [invoiceId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
}

model CustomerFeedback {
  id         String   @id @default(cuid())
  customerId String
  category   String
  subject    String
  message    String
  rating     Int?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model ActivityEvent {
  id          String   @id @default(cuid())
  customerId  String
  type        String
  title       String
  description String
  link        String?
  occurredAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

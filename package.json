{
    "name": "app",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:full": "concurrently -k -n WEB,API -c cyan,green \"npm:dev\" \"npm:api:dev\"",
        "build": "npm run prisma:generate && tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "api:dev": "tsx watch server/src/index.ts",
        "api:build": "tsc -p server/tsconfig.json",
        "db:ensure": "tsx server/scripts/ensureDatabase.ts",
        "prisma:generate": "node scripts/prisma-generate.mjs",
        "prisma:migrate": "prisma migrate dev --schema server/prisma/schema.prisma",
        "prisma:deploy": "prisma migrate deploy --schema server/prisma/schema.prisma",
        "prisma:seed": "tsx server/prisma/seed.ts",
        "postinstall": "npm run prisma:generate"
    },
    "dependencies": {
        "@prisma/client": "^6.8.2",
        "@stripe/react-stripe-js": "^6.2.0",
        "@stripe/stripe-js": "^9.2.0",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/react-query": "^5.99.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.5.0",
        "express": "^4.21.2",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "pg": "^8.20.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-router-dom": "^7.14.1",
        "stripe": "^22.0.2",
        "tailwindcss": "^4.2.2",
        "zod": "^3.24.4",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/morgan": "^1.9.9",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.2.1",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "prisma": "^6.8.2",
        "tsx": "^4.19.4",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.4"
    }
}